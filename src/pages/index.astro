          <div class="font-mono text-[11px] uppercase tracking-[0.18em]">
            <div class="grid grid-cols-12 gap-x-6 py-3 border-b border-rule/60">
              <div class="col-span-6 md:col-span-3 text-muted">2024 — 2025</div>
              <div class="col-span-6 md:col-span-3 text-ink"
                   data-i18n data-en="Tianlan Technology" data-zh="天蓝色科技">Tianlan Technology</div>
              <div class="col-span-12 md:col-span-4 mt-2 md:mt-0 text-ink2"
                   data-i18n data-en="FMCG e-commerce · Data Analyst" data-zh="快消电商 · 数据分析师">FMCG e-commerce · Data Analyst</div>
              <div class="col-span-12 md:col-span-2 mt-1 md:mt-0 md:text-right text-muted"
