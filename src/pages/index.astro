                  <li class="font-mono text-[12px] px-2.5 py-1.5 border border-rule text-ink hover:border-ink hover:bg-ink hover:text-paper transition-colors cursor-default"
                      data-i18n data-en="KPI Framework" data-zh="指标体系">KPI Framework</li>
                  <li class="font-mono text-[12px] px-2.5 py-1.5 border border-rule text-ink hover:border-ink hover:bg-ink hover:text-paper transition-colors cursor-default"
