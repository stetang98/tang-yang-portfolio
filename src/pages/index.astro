---
import "../styles/global.css";
---

<!doctype html>
<html lang="en" data-lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Tang Yang — Data Analyst. Indicator frameworks, BI dashboards, attribution analysis, consumer insights." />
    <title>Tang Yang — Data Analyst</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,300;0,6..72,400;0,6..72,500;1,6..72,300;1,6..72,400&family=IBM+Plex+Sans:wght@300;400;500;600&family=IBM+Plex+Mono:wght@400;500&family=Noto+Serif+SC:wght@300;400;500&family=Noto+Sans+SC:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="antialiased">

    <!-- ============ HEADER ============ -->
    <header id="hdr" class="fixed inset-x-0 top-0 z-40 transition-all duration-300 border-b border-transparent">
      <div class="mx-auto w-full max-w-[1280px] px-6 md:px-10 lg:px-14 flex h-16 items-center justify-between">
        <a href="#top" class="group flex items-baseline gap-3">
          <span class="font-display text-[19px] tracking-tight"
                data-i18n data-en="Tang Yang" data-zh="汤洋">Tang Yang</span>
          <span class="hidden sm:inline font-mono text-[10px] uppercase tracking-[0.22em] text-muted group-hover:text-ink transition"
                data-i18n data-en="Data Analyst" data-zh="数据分析师">Data Analyst</span>
        </a>

        <nav class="hidden md:flex items-center gap-9 font-mono text-[12px] uppercase tracking-[0.18em] text-ink2">
          <a class="arrow-link" href="#about"   data-i18n data-en="About"   data-zh="关于">About</a>
          <a class="arrow-link" href="#contact" data-i18n data-en="Contact" data-zh="联系">Contact</a>
        </nav>

        <div class="flex items-center gap-1 font-mono text-[12px] tracking-[0.14em]">
          <button id="lang-en" class="px-2 py-1 rounded-sm transition text-ink" aria-pressed="true">EN</button>
          <span class="text-rule">/</span>
          <button id="lang-zh" class="px-2 py-1 rounded-sm transition text-muted hover:text-ink" aria-pressed="false">CN</button>
        </div>
      </div>
    </header>

    <main>
      <!-- ============ HERO ============ -->
      <section id="top" class="relative pt-32 md:pt-40 pb-20 md:pb-28 grain">
        <div class="mx-auto w-full max-w-[1280px] px-6 md:px-10 lg:px-14">

          <div class="flex items-center justify-between font-mono text-[11px] uppercase tracking-[0.18em] text-muted">
            <span data-i18n data-en="Portfolio" data-zh="作品集">Portfolio</span>
            <span>N 31.2° / E 121.4°</span>
          </div>
          <div class="mt-3 h-px w-full bg-rule"></div>

          <div class="mt-10 md:mt-14 grid grid-cols-12 gap-x-6 gap-y-12 items-start">

            <!-- Left: kicker + H1 -->
            <div class="col-span-12 lg:col-span-8">
              <div class="font-mono text-[12px] uppercase tracking-[0.22em] text-accent mb-6"
                   data-i18n
                   data-en="Data Analyst · Metrics · BI · Insights"
                   data-zh="数据分析师 · 指标 · BI · 洞察">
                Data Analyst · Metrics · BI · Insights
              </div>

              <h1 class="font-display text-[14vw] sm:text-[12vw] md:text-[9.5vw] lg:text-[8.2vw] leading-[0.92] tracking-[-0.025em] text-ink">
                <span class="block" data-i18n data-en="Numbers narrate." data-zh="数字会说话。">Numbers narrate.</span>
                <span class="block italic font-light text-ink2"
                      data-i18n data-en="I write the sentences." data-zh="我把它讲清楚。">I write the sentences.</span>
              </h1>
            </div>

            <!-- Right: analyst card -->
            <aside class="col-span-12 lg:col-span-4 lg:pt-2">
              <div class="font-mono text-[11px] uppercase tracking-[0.22em] text-muted"
                   data-i18n data-en="— The analyst" data-zh="— 分析师">— The analyst</div>

              <div class="mt-4 font-display text-3xl md:text-4xl tracking-tight"
                   data-i18n data-en="Tang Yang" data-zh="汤洋">Tang Yang</div>

              <p class="mt-5 max-w-sm text-[15px] leading-[1.65] text-ink2"
                 data-i18n
                 data-en="Three years in. Indicator frameworks, quantitative modeling, attribution and anomaly analysis, BI dashboards."
                 data-zh="数据分析 3 年。指标体系、量化测算、归因分析、异动分析、BI 看板。">
                Three years in. Indicator frameworks, quantitative modeling, attribution and anomaly analysis, BI dashboards.
              </p>

              <div class="mt-6 font-mono text-[11px] uppercase tracking-[0.18em] text-muted"
                   data-i18n data-en="Based in Shanghai" data-zh="常驻上海">Based in Shanghai</div>
            </aside>
          </div>

          <!-- CTAs -->
          <div class="mt-14 md:mt-20 flex flex-col sm:flex-row items-stretch sm:items-center gap-3">
            <a href="/Tang_Yang_Data_Analyst.pdf"
               class="group inline-flex items-center justify-between gap-6 bg-ink text-paper px-6 py-4 hover:bg-accent transition-colors"
