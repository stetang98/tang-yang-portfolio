              <div class="col-span-12 md:col-span-2 mt-1 md:mt-0 md:text-right text-muted"
                   data-i18n data-en="Shanghai" data-zh="上海">Shanghai</div>
            </div>
            <div class="grid grid-cols-12 gap-x-6 py-3">
              <div class="col-span-6 md:col-span-3 text-muted">2016 — 2022</div>
              <div class="col-span-6 md:col-span-3 text-ink"
                   data-i18n data-en="Yangtze University" data-zh="长江大学">Yangtze University</div>
              <div class="col-span-12 md:col-span-4 mt-2 md:mt-0 text-ink2"
