          </div>

          <div class="mt-14 mb-10 h-px w-full bg-rule"></div>

          <a href="mailto:823138943@qq.com" class="group block">
            <div class="font-mono text-[11px] uppercase tracking-[0.22em] text-muted mb-3"
                 data-i18n data-en="Email" data-zh="邮箱">Email</div>
            <div class="font-display text-[clamp(2rem,7vw,5rem)] tracking-tight text-ink group-hover:text-accent transition-colors break-all">
              823138943@qq.com
            </div>
          </a>

          <div class="mt-12 mb-6 h-px w-full bg-rule"></div>

          <div class="flex flex-col sm:flex-row gap-3 sm:items-center justify-between font-mono text-[11px] uppercase tracking-[0.18em]">
            <span class="text-muted"
