    <script is:inline>
      // ---- Lang toggle ----
      const STORE_KEY = "tangyang.lang";
      const root = document.documentElement;
      const btnEn = document.getElementById("lang-en");
      const btnZh = document.getElementById("lang-zh");

      function applyLang(lang) {
        const next = lang === "zh" ? "zh" : "en";
        document.body.classList.add("lang-fading");
        setTimeout(() => {
          root.setAttribute("data-lang", next);
          root.setAttribute("lang", next === "zh" ? "zh-CN" : "en");

          document.querySelectorAll("[data-i18n]").forEach((el) => {
            const val = next === "zh" ? el.getAttribute("data-zh") : el.getAttribute("data-en");
            if (val != null) el.textContent = val;
          });

          btnEn.classList.toggle("text-ink", next === "en");
          btnEn.classList.toggle("text-muted", next !== "en");
          btnZh.classList.toggle("text-ink", next === "zh");
          btnZh.classList.toggle("text-muted", next !== "zh");
          btnEn.setAttribute("aria-pressed", String(next === "en"));
          btnZh.setAttribute("aria-pressed", String(next === "zh"));
          btnEn.classList.toggle("hover:text-ink", next !== "en");
          btnZh.classList.toggle("hover:text-ink", next !== "zh");

          try { localStorage.setItem(STORE_KEY, next); } catch (e) {}
          requestAnimationFrame(() => document.body.classList.remove("lang-fading"));
        }, 140);
      }

      btnEn.addEventListener("click", () => applyLang("en"));
      btnZh.addEventListener("click", () => applyLang("zh"));

      // init from localStorage — always hydrate textContent
      let stored = "en";
      try { stored = localStorage.getItem(STORE_KEY) || "en"; } catch (e) {}
      const initLang = stored === "zh" ? "zh" : "en";
      root.setAttribute("data-lang", initLang);
      root.setAttribute("lang", initLang === "zh" ? "zh-CN" : "en");
      document.querySelectorAll("[data-i18n]").forEach((el) => {
        const val = el.getAttribute(initLang === "zh" ? "data-zh" : "data-en");
        if (val != null) el.textContent = val;
      });
      if (initLang === "zh") {
        btnEn.classList.replace("text-ink", "text-muted");
        btnEn.classList.add("hover:text-ink");
        btnZh.classList.replace("text-muted", "text-ink");
        btnZh.classList.remove("hover:text-ink");
        btnEn.setAttribute("aria-pressed", "false");
        btnZh.setAttribute("aria-pressed", "true");
      }

      // ---- Sticky header blur on scroll ----
      const hdr = document.getElementById("hdr");
      const onScroll = () => {
        if (window.scrollY > 12) hdr.classList.add("scrolled");
        else hdr.classList.remove("scrolled");
      };
      window.addEventListener("scroll", onScroll, { passive: true });
      onScroll();
    </script>
