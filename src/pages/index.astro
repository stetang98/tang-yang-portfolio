          <!-- Languages + Industries footnote -->
          <div class="mt-8 grid grid-cols-12 gap-x-6 gap-y-3 font-mono text-[11px] uppercase tracking-[0.18em] text-muted">
            <div class="col-span-12 md:col-span-3"
